{
  "name": "recarga-nequi-sistema-unificado",
  "version": "2.1.0",
  "description": "Sistema unificado de recarga Nequi con PSE, cloaker, alta concurrencia y reverse proxy Nginx",
  "main": "server.js",
  "type": "commonjs",
  "scripts": {
    "start": "node server.js",
    "start:cluster": "node cluster.js",
    "dev": "nodemon server.js",
    "build": "echo 'No build step required'",
    "prod": "NODE_ENV=production node server.js",
    "docker:build": "docker compose build",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f"
  },
  "keywords": [
    "nequi",
    "pse",
    "telegram",
    "bancolombia",
    "banco",
    "socket.io",
    "cloaker",
    "nginx"
  ],
  "author": "",
  "license": "ISC",
  "engines": {
    "node": ">=20.0.0 <25.0.0",
    "npm": ">=10.0.0"
  },
  "dependencies": {
    "@socket.io/redis-adapter": "^8.3.0",
    "axios": "^1.6.0",
    "compression": "^1.7.4",
    "express": "^4.18.2",
    "express-rate-limit": "^7.4.0",
    "helmet": "^7.1.0",
    "node-telegram-bot-api": "^0.64.0",
    "redis": "^4.7.0",
    "socket.io": "^4.6.1"
  },
  "devDependencies": {
    "nodemon": "^3.0.1"
  }
}
